# Qwen3.5-27B (Q8_0, ~29GB) — Agentic Coding & Tool Use
# Architecture: 27B dense params
# Context: 262,144 native (extensible to 1M via YaRN)

FROM qwen3.5:27b-q8_0

# --- Sampling: Thinking Mode + Precise Coding (Qwen official) ---
# temperature=0.6, top_p=0.95, top_k=20, min_p=0 — Qwen recommended for thinking+coding
# repeat_penalty=1.0 — disabled per Qwen (no benefit, can hurt)
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER min_p 0.0
PARAMETER repeat_penalty 1.0

# --- Context & Generation ---
PARAMETER num_ctx 262144
PARAMETER num_predict 65536
